{
  "name": "capstone-project",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <23",
    "npm": ">=10"
  },
  "dependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "prop-types": "^15.7.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "react-scripts": "4.0.3",
    "react-spinners": "^0.17.0",
    "styled-components": "^5.3.0",
    "uuidv4": "^6.2.10",
    "web-vitals": "^1.1.2"
  },
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "react-scripts test",
    "lint": "eslint \"src/**/*.{js,jsx}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,json,md,yml,yaml,css,html}\"",
    "storybook": "STORYBOOK_DISABLE_TELEMETRY=1 storybook dev -p 6006",
    "build-storybook": "STORYBOOK_DISABLE_TELEMETRY=1 storybook build"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "overrides": [
      {
        "files": [
          "**/*.stories.*"
        ],
        "rules": {
          "import/no-anonymous-default-export": "off"
        }
      }
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-links": "^8.6.18",
    "@storybook/react-webpack5": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^7.32.0",
    "prettier": "^3.8.1",
    "storybook": "^8.6.18",
    "vite": "^5.4.21"
  }
}
